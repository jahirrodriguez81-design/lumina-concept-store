{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/apply-promo",  "dest": "/api/apply-promo.js" },
    { "src": "/api/config",       "dest": "/api/config.js" },
    { "src": "/api/quote",        "dest": "/api/quote.js" },
    { "src": "/api/create-order", "dest": "/api/create-order.js" },
    { "src": "/api/capture-order","dest": "/api/capture-order.js" },
    { "src": "/api/admin-orders", "dest": "/api/admin-orders.js" },
    { "src": "/(.*)",             "dest": "/$1" }
  ]
}
