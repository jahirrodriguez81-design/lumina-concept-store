# ─────────────────────────────────────────────────────────
# Lumina Concept Store — Variables de entorno
# Copia este archivo como .env y completa los valores reales
# ─────────────────────────────────────────────────────────

# Credenciales de PayPal Sandbox
# Obtén las tuyas en: https://developer.paypal.com → Apps & Credentials → Sandbox
PAYPAL_CLIENT_ID=tu_sandbox_client_id_aqui
PAYPAL_SECRET=tu_sandbox_secret_aqui

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
