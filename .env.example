# ─────────────────────────────────────────────────────────────
# Lumina Concept Store — Variables de entorno
# Copia este archivo como .env y completa los valores reales
# ─────────────────────────────────────────────────────────────

# ── PayPal ────────────────────────────────────────────────────
# Sandbox: developer.paypal.com → Apps & Credentials → Sandbox
# Live: cambia a live y usa credenciales de producción
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=tu_sandbox_client_id_aqui
PAYPAL_SECRET=tu_sandbox_secret_aqui

# ── Supabase ──────────────────────────────────────────────────
# supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Panel admin ───────────────────────────────────────────────
# Token secreto para acceder a /admin.html
ADMIN_TOKEN=cambia-esto-por-un-token-secreto

# ── General ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
